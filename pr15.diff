+    storage = new MockInventoryStorage()
+    service = new InventoryAllocationService(storage)
+  })
+
+  describe('reserveStock', () => {
+    it('successfully reserves stock when available', () => {
+      storage.__setRecord({
+        sku: 'TEST-SKU',
