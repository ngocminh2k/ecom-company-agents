# AgentPulse Commerce — Daemon Configuration
# Copy to .env to override defaults

# ─── Server ─────────────────────────────────────────────
PORT=7456
BIND_HOST=127.0.0.1

# ─── Data Paths (default: relative to monorepo root) ───
# SKILLS_DIR=./skills
# DESIGN_SYSTEMS_DIR=./design-systems
# PLUGINS_DIR=./plugins
# DATA_DIR=./data
# DATABASE_PATH=./data/ecc.db
# ARTIFACTS_DIR=./data/artifacts

# ─── CORS ───────────────────────────────────────────────
CORS_ENABLED=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# ─── LLM BYOK Proxy ─────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ─── Docker / Auth ──────────────────────────────────────
# API_TOKEN=                 # generate via: openssl rand -hex 32

# ─── E-Commerce Integrations ────────────────────────────
# PRINTFUL_API_KEY=...
# PRINTIFY_API_KEY=...
# SHOPIFY_API_KEY=...
# SHOPIFY_STORE_URL=...
